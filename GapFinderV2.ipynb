# Builds gap profiles — outcomes where model predicts NOT mastered
gap_profiles = []

for i, (student_id, pred_row, prob_row) in enumerate(
    zip(test_df["Student ID"].values, test_preds, test_probs)
):
    if not fail_mask[i]:
        continue

    gaps = []
    for j, outcome in enumerate(outcome_names):
        if pred_row[j] == 0:  # Model predicts not mastered
            gaps.append({
                "Outcome": outcome,
                "Mastery Probability": round(float(prob_row[j]), 3),
                "Gap Severity": "High" if prob_row[j] < 0.3 else "Moderate"
            })

    # Sort gaps by severity (lowest mastery probability first)
    gaps = sorted(gaps, key=lambda x: x["Mastery Probability"])

    gap_profiles.append({
        "Student ID": student_id,
        "Total Gaps": len(gaps),
        "Profile Type": (
            "Concentrated" if len(gaps) <= 8
            else "Broad" if len(gaps) >= 16
            else "Moderate"
        ),
        "Gaps": gaps
    })

print(f"\nGap profiles generated for {len(gap_profiles)} failing candidates")

# Profile type distribution
types = [p["Profile Type"] for p in gap_profiles]
from collections import Counter
print(f"\nProfile types: {Counter(types)}")

# 8.6b Add strengths to gap profiles

id_to_idx = {sid: i for i, sid in enumerate(test_df["Student ID"].values)}

for profile in gap_profiles:
    idx = id_to_idx[profile["Student ID"]]
    prob_row = test_probs[idx]
    pred_row = test_preds[idx]

    strengths = []
    for j, outcome in enumerate(outcome_names):
        if pred_row[j] == 1:
            strengths.append({
                "Outcome": outcome,
                "Mastery Probability": round(float(prob_row[j]), 3),
                "Mastery Level": "Strong" if prob_row[j] >= 0.80 else "Good"
            })

    # Highest mastery first
    strengths = sorted(strengths, key=lambda x: -x["Mastery Probability"])
    profile["Strengths"] = strengths
    profile["Total Strengths"] = len(strengths)

print(f"Strengths added to {len(gap_profiles)} profiles")
avg = sum(p["Total Strengths"] for p in gap_profiles) / len(gap_profiles)
print(f"Average strengths per candidate: {avg:.1f}")


# Updated profile printer — shows gaps and strengths together
def print_full_profile(profile):
    print(f"\n{'='*70}")
    print(f"Student ID:    {profile['Student ID']}")
    print(f"Profile Type:  {profile['Profile Type']}")
    print(f"Gaps:          {profile['Total Gaps']} / {n_outcomes} outcomes not mastered")
    print(f"Strengths:     {profile['Total Strengths']} / {n_outcomes} outcomes mastered")
    print(f"{'='*70}")

    print("\nFocus Areas (lowest mastery first):\n")
    if profile["Total Gaps"] >= 16:
        print("  WARNING: Broad failure pattern — full restudy recommended\n")

    for rank, gap in enumerate(profile["Gaps"], 1):
        bar = "█" * int(gap["Mastery Probability"] * 10) + "░" * (10 - int(gap["Mastery Probability"] * 10))
        print(f"  {rank}. [{gap['Gap Severity']}] {gap['Outcome'][:55]}")
        print(f"     Mastery: {gap['Mastery Probability']:.0%}  {bar}\n")

    print("Demonstrated Strengths (highest mastery first):\n")
    if not profile["Strengths"]:
        print("  No mastered outcomes identified.")
    else:
        for rank, s in enumerate(profile["Strengths"], 1):
            bar = "█" * int(s["Mastery Probability"] * 10)
            print(f"  {rank}. [{s['Mastery Level']}] {s['Outcome'][:55]}")
            print(f"     Mastery: {s['Mastery Probability']:.0%}  {bar}\n")


# Prints first 3 profiles to check output
for profile in gap_profiles[:3]:
    print_full_profile(profile)

# 8.7 Sample gap profile output

def print_gap_profile(profile):
    """
    Prints a readable gap profile for a single candidate.
    This is the format GapFinder would deliver to a learner or educator.
    """
    print(f"{'='*70}")
    print(f"Student ID:    {profile['Student ID']}")
    print(f"Profile Type:  {profile['Profile Type']}")
    print(f"Total Gaps:    {profile['Total Gaps']} / {n_outcomes} outcomes")
    print(f"{'='*70}")

    if profile["Total Gaps"] >= 16:
        print("⚠️  BROAD FAILURE PATTERN DETECTED")
        print("This candidate requires comprehensive review across most")
        print("syllabus areas. Topic-specific intervention alone is unlikely")
        print("to be sufficient. Consider a structured restudy programme.\n")
    else:
        print("Priority study areas (lowest mastery first):\n")

    for rank, gap in enumerate(profile["Gaps"][:8], 1):
        bar = "█" * int(gap["Mastery Probability"] * 10)
        print(f"  {rank}. [{gap['Gap Severity']:8s}] {gap['Outcome'][:60]}")
        print(f"            Mastery probability: {gap['Mastery Probability']:.0%}  {bar}")
        print()

# Prints profile for first 3 failing candidates
for profile in gap_profiles[:3]:
    print_gap_profile(profile)

