# 8.5 Shap values per learning outcome

# For each learning outcome, show which questions drive its mastery prediction
def plot_outcome_shap(outcome_idx, outcome_name, shap_values, top_n=10):
    """
    Plots the top N most influential questions for a given learning outcome.
    Positive SHAP = pushes towards mastered, Negative = pushes towards not mastered.
    """
    sv = shap_values[outcome_idx]  # Shape: (n_test, n_questions)
    mean_shap = sv.mean(axis=0)    # Average effect per question

    # Gets top N by absolute value
    top_idx = np.argsort(np.abs(mean_shap))[-top_n:][::-1]
    top_vals = mean_shap[top_idx]
    top_qs   = [f"Q{i+1}" for i in top_idx]

    colors = ["steelblue" if v > 0 else "tomato" for v in top_vals]

    fig, ax = plt.subplots(figsize=(10, 5))
    ax.barh(top_qs, top_vals, color=colors)
    ax.axvline(x=0, color="black", linewidth=0.8)
    ax.set_xlabel("Mean SHAP Value\n(Blue = towards mastered, Red = towards not mastered)")
    ax.set_title(f"SHAP — {outcome_name[:70]}")
    ax.invert_yaxis()
    plt.tight_layout()
    return fig

